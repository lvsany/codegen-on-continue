ndition; convert root if necessary.\n+            pass\n \n     def _insert_into_parent(self, parent, key, node):\n         \"\"\"\n         Helper method to insert a key into the parent of a split node.\n         \"\"\"\n-        # This method should implement the logic to add\n-        pass\n+        # Insert the key into the parent node\n+        # This is a simplified version and might need changes based on specific node/parent structure.\n+        for i, item in enumerate(parent.keys):\n+            if key < item:\n+                parent.keys.insert(i, key)\n+                parent.children.insert(i + 1, node)\n+                break\n+        else:  # If the key is larger than all keys, append it to the end\n+            parent.keys.append(key)\n+            parent.children.append(node)\n+\n+        # Check if split is required for parent\n+        if len(parent.keys) >= self.order:\n+            self._split_internal_node(parent)\n+\n+    def _split_internal_node(self, internal_node):\n+        \"\"\"\n+        Splits internal node and adjusts tree structure accordingly.\n+        \"\"\"\n+        mid = len(internal_node.keys) // 2\n+        new_internal = InternalNode()\n+\n+        # Shift keys\n+        new_internal.keys = internal_node.keys[mid + 1:]\n+        new_internal.children = internal_node.children[mid + 1:]\n+\n+        # Shrink original node\n+        internal_node.keys = internal_node.keys[:mid]\n+        internal_node.children = internal_node.children[:mid + 1]\n+\n+        # Handle parent adjustment\n+        if internal_node.parent:\n+            self._insert_into_parent(internal_node.parent, internal_node.keys[mid], new_internal)\n+        else:\n+            # Create new root\n+            new_root = InternalNode(keys=[internal_node.keys[mid]], children=[internal_node, new_internal], is_leaf=False)\n+            self.root = new_root\n+            internal_node.parent = new_root\n+            new_internal.parent = new_root\n+\n+\n+class LeafNode:\n+    \"\"\"\n+    Class representing the leaf node of a B+ tree.\n+    \"\"\"\n+    def __init__(self, keys=None, values=None, parent=None, next=None):\n+        self.keys = keys if keys is not None else []\n+        self.values = values if values is not None else []\n+        self.parent = parent\n+        self.next = next\n+\n+    def is_leaf_node(self):\n+        return True\n+\n+\n+class InternalNode:\n+    \"\"\"\n+    Class representing the internal node of a B+ tree.\n+    \"\"\"\n+    def __init__(self, keys=None, children=None, is_leaf=False, parent=None):\n+        self.keys = keys if keys is not None else []\n+        self.children = children if children is not None else []\n+        self.is_leaf = is_leaf\n+        self.parent = parent\n+\n+    def is_leaf_node(self):\n+        return self.is_leaf\n\n</History>\n    \n", "output_text": "{\"code\":\"class BPlusTree:\\n    \\\"\\\"\\\"\\n    Class representing the B+ tree data structure.\\n    \\\"\\\"\\\"\\n    def __init__(self, root, order):\\n        \\\"\\\"\\\"\\n        Initializes the B+ tree with a given root and order.\\n        \\\"\\\"\\\"\\n        self.root = root  # The root node of the B+ tree.\\n        self.order = order  # The order of the B+ tree.\\n\\n    def insert(self, key: int, value: any) -> None:\\n        \\\"\\\"\\\"\\n        Inserts a key-value pair into the B+ tree.\\n        \\n        Parameters:\\n        key (int): The key to insert into the tree.\\n        value (any): The value associated with the key.\\n        \\\"\\\"\\\"\\n        leaf_node = self._find_leaf_node(self.root, key)\\n\\n        leaf_node.keys.append(key)\\n        leaf_node.values.append(value)\\n\\n        keys_and_values = sorted(zip(leaf_node.keys, leaf_node.values))\\n        leaf_node.keys, leaf_node.values = zip(*keys_and_values)\\n\\n        if len(leaf_node.keys) >= self.order:\\n            self._split_leaf_node(leaf_node)\\n\\n    def search(self, key: int) -> any:\\n        \\\"\\\"\\\"\\n        Searches for a key in the B+ tree and returns its associated value.\\n        \\n        Parameters:\\n        key (int): The key to search for in the tree.\\n        \\\"\\\"\\\"\\n        current_node = self.root\\n        \\n        while not current_node.is_leaf_node():\\n            for i, item in enumerate(current_node.keys):\\n                if key < item:\\n                    current_node = current_node.children[i]\\n                    break\\n            else:\\n                current_node = current_node.children[-1]\\n\\n        for k, v in zip(current_node.keys, current_node.values):\\n            if k == key:\\n                return v\\n        return None\\n\\n    def delete(self, key: int) -> None:\\n        \\\"\\\"\\\"\\n        Deletes a key-value pair from the B+ tree.\\n        \\n        Parameters:\\n        key (int): The key to delete from the tree.\\n        \\\"\\\"\\\"\\n        leaf_node = self._find_leaf_node(self.root, key)\\n\\n        if key in leaf_node.keys:\\n            index = leaf_node.keys.index(key)\\n            leaf_node.keys.pop(index)\\n            leaf_node.values.pop(index)\\n            \\n            if len(leaf_node.keys) < (self.order - 1) // 2:\\n                self._rebalance_tree(leaf_node)\\n\\n    def _find_leaf_node(self, node, key):\\n        \\\"\\\"\\\"\\n        Helper method to find the leaf node where a key should reside.\\n        \\\"\\\"\\\"\\n        current_node = node\\n        while not current_node.is_leaf_node():\\n            for i, item in enumerate(current_node.keys):\\n                if key < item:\\n                    current_node = current_node.children[i]\\n                    break\\n            else:\\n                current_node = current_node.children[-1]\\n        return current_node\\n\\n    def _split_leaf_node(self, leaf_node):\\n        \\\"\\\"\\\"\\n        Helper method to split a leaf node when it overflows.\\n        \\\"\\\"\\\"\\n        mid = len(leaf_node.keys) // 2\\n        \\n        new_leaf = LeafNode()\\n        \\n        new_leaf.keys = leaf_node.keys[mid:]\\n        new_leaf.values = leaf_node.values[mid:]\\n        leaf_node.keys = leaf_node.keys[:mid]\\n        leaf_node.values = leaf_node.values[:mid]\\n\\n        new_leaf.next = leaf_node.next\\n        leaf_node.next = new_leaf\\n\\n        if leaf_node.parent:\\n            self._insert_into_parent(leaf_node.parent, new_leaf.keys[0], new_leaf)\\n\\n    def _rebalance_tree(self, node):\\n        \\\"\\\"\\\"\\n        Helper method to rebalance the tree when a node underflows.\\n        \\\"\\\"\\\"\\n        parent_node = node.parent\\n        if parent_node:  # Borrow from sibling or merge with sibling\\n            left_sibling = self._get_left_sibling(node)\\n            right_sibling = self._get_right_sibling(node)\\n\\n            if left_sibling and len(left_sibling.keys) > (self.order - 1) // 2:\\n                # Borrow from left sibling\\n                borrowed_key = left_sibling.keys.pop(-1)\\n                borrowed_value = left_sibling.values.pop(-1)\\n                node.keys.insert(0, borrowed_key)\\n                node.values.insert(0, borrowed_value)\\n                parent_index = parent_node.keys.index(node.keys[0])\\n                parent_node.keys[parent_index] = borrowed_key\\n            elif right_sibling and len(right_sibling.keys) > (self.order - 1) // 2:\\n                # Borrow from right sibling\\n                borrowed_key = right_sibling.keys.pop(0)\\n                borrowed_value = right_sibling.values.pop(0)\\n                node.keys.append(borrowed_key)\\n                node.values.append(borrowed_value)\\n                parent_index = parent_node.keys.index(right_sibling.keys[0])\\n                parent_node.keys[parent_index] = node.keys[-1]\\n            else:\\n                # Merge with sibling\\n                if left_sibling:\\n                    left_sibling.keys.extend(node.keys)\\n                    left_sibling.values.extend(node.values)\\n                    left_sibling.next = node.next\\n                    parent_node.keys.remove(node.keys[0])\\n                    parent_node.children.remove(node)\\n                elif right_sibling:\\n                    node.keys.extend(right_sibling.keys)\\n                    node.values.extend(right_sibling.values)\\n                    node.next = right_sibling.next\\n                    parent_node.keys.remove(right_sibling.keys[0])\\n                    parent_node.children.remove(right_sibling)\\n\\n                if len(parent_node.keys) < (self.order - 1) // 2:\\n                    self._rebalance_tree(parent_node)\\n\\n        else:\\n            \\\"\\\"\\\"Root condition; convert root if necessary.\\\"\\\"\\\"\\n            if len(node.keys) == 0:\\n                self.root = node.children[0]\\n                self.root.parent = None\\n\\n    def _insert_into_parent(self, parent, key, node):\\n        \\\"\\\"\\\"\\n        Helper method to insert a key into the parent of a split node.\\n        \\\"\\\"\\\"\\n        for i, item in enumerate(parent.keys):\\n            if key < item:\\n                parent.keys.insert(i, key)\\n                parent.children.insert(i + 1, node)\\n                break\\n        else:\\n            parent.keys.append(key)\\n            parent.children.append(node)\\n\\n        if len(parent.keys) >= self.order:\\n            self._split_internal_node(parent)\\n\\n    def _split_internal_node(self, internal_node):\\n        \\\"\\\"\\\"\\n        Splits internal node and adjusts tree structure accordingly.\\n        \\\"\\\"\\\"\\n        mid = len(internal_node.keys) // 2\\n        new_internal = InternalNode()\\n\\n        new_internal.keys = internal_node.keys[mid + 1:]\\n        new_internal.children = internal_node.children[mid + 1:]\\n\\n        internal_node.keys = internal_node.keys[:mid]\\n        internal_node.children = internal_node.children[:mid + 1]\\n\\n        if internal_node.parent:\\n            self._insert_into_parent(internal_node.parent, internal_node.keys[mid], new_internal)\\n        else:\\n            new_root = InternalNode(keys=[internal_node.keys[mid]], children=[internal_node, new_internal], is_leaf=False)\\n            self.root = new_root\\n            internal_node.parent = new_root\\n            new_internal.parent = new_root\\n\\n    def _get_left_sibling(self, node):\\n        \\\"\\\"\\\"\\n        Helper method to get the left sibling of a node.\\n        \\\"\\\"\\\"\\n        parent_node = node.parent\\n        if parent_node:\\n            index = parent_node.children.index(node)\\n            if index > 0:\\n                return parent_node.children[index - 1]\\n        return None\\n\\n    def _get_right_sibling(self, node):\\n        \\\"\\\"\\\"\\n        Helper method to get the right sibling of a node.\\n        \\\"\\\"\\\"\\n        parent_node = node.parent\\n        if parent_node:\\n            index = parent_node.children.index(node)\\n            if index < len(parent_node.children) - 1:\\n                return parent_node.children[index + 1]\\n        return None\\n\\n\\nclass LeafNode:\\n    \\\"\\\"\\\"\\n    Class representing the leaf node of a B+ tree.\\n    \\\"\\\"\\\"\\n    def __init__(self, keys=None, values=None, parent=None, next=None):\\n        self.keys = keys if keys is not None else []\\n        self.values = values if values is not None else []\\n        self.parent = parent\\n        self.next = next\\n\\n    def is_leaf_node(self):\\n        return True\\n\\n\\nclass InternalNode:\\n    \\\"\\\"\\\"\\n    Class representing the internal node of a B+ tree.\\n    \\\"\\\"\\\"\\n    def __init__(self, keys=None, children=None, is_leaf=False, parent=None):\\n        self.keys = keys if keys is not None else []\\n        self.children = children if children is not None else []\\n        self.is_leaf = is_leaf\\n        self.parent = parent\\n\\n    def is_leaf_node(self):\\n        return self.is_leaf\\n\",\"path\":\"src/bplustree.py\"}"}
