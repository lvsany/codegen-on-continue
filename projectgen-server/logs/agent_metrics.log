se associated value is to be retrieved.'}], 'return_type': 'long'}, {'name': 'bplus_tree_put', 'description': 'Insert a key-value pair into the B+ tree or remove a key if the data parameter is set to 0.', 'parameters': [{'name': 'tree', 'type': 'struct bplus_tree*', 'description': 'The B+ tree to modify.'}, {'name': 'key', 'type': 'long', 'description': 'The key to insert or remove.'}, {'name': 'data', 'type': 'long', 'description': 'The value to associate with the key; if 0, the key is removed.'}], 'return_type': 'int'}, {'name': 'bplus_tree_get_range', 'description': 'Retrieve all values within a specified key range in the B+ tree.', 'parameters': [{'name': 'tree', 'type': 'struct bplus_tree*', 'description': 'The B+ tree to search through.'}, {'name': 'key1', 'type': 'long', 'description': 'The start key of the range.'}, {'name': 'key2', 'type': 'long', 'description': 'The end key of the range.'}], 'return_type': 'void'}], 'global_code': {'globalVariables': [], 'globalBlocks': []}}\n```\n</Target_File_SSAT>\n", "output_text": "{\"path\":\"lib/bplustree.h\",\"skeleton_code\":\"# bplustree.h\\n# Defines the core data structures and the API for the B+ tree.\\n\\ndef bplus_tree_init(filename: str, block_size: int) -> 'struct bplus_tree*':\\n    \\\"\\\"\\\"\\n    Initialize a B+ tree from file or create a new one, setting up the necessary structures for persistent storage.\\n    :param filename: The name of the file to store the B+ tree.\\n    :param block_size: Specifies the block size (must be a power of 2) to determine maximum entries per node.\\n    :return: struct bplus_tree*\\n    \\\"\\\"\\\"\\n    pass\\n\\ndef bplus_tree_deinit(tree: 'struct bplus_tree*') -> None:\\n    \\\"\\\"\\\"\\n    Clean up resources used by the B+ tree and save metadata to the boot file for future reconstruction.\\n    :param tree: The B+ tree structure to be deinitialized.\\n    :return: None\\n    \\\"\\\"\\\"\\n    pass\\n\\ndef bplus_tree_get(tree: 'struct bplus_tree*', key: int)