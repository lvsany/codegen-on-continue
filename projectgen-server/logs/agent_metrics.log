t path\\n\\n# Check if 'bplustree.memory' can be imported\\nmodule_name = 'bplustree.memory'\\nif importlib.util.find_spec(module_name) is None:\\n    # If the module is not available, raise a clear ImportError\\n    raise ImportError(f\\\"The module '{module_name}' is not found. Ensure it is installed and properly located.\\\")\\nelse:\\n    from bplustree.memory import FileMemory  # Adjusted to load FileMemory correctly\\n\\nclass Node:\\n    def __init__(self, is_leaf=False):\\n        self.is_leaf = is_leaf\\n        self.keys = []\\n        self.children = []\\n\\nclass BPlusTree:\\n    \\\"\\\"\\\"Encapsulates the B+ tree operations and properties.\\\"\\\"\\\"\\n    \\n    def __init__(self, order):\\n        \\\"\\\"\\\"Initializes the B+ tree with a specified order.\\\"\\\"\\\"\\n        self.root = Node(is_leaf=True)  # The root node of the B+ tree is initially a leaf node.\\n        self.order = order  # Maximum number of children a node can have.\\n\\n    def insert(self, key, value):\\n        \\\"\\\"\\\"Inserts a key-value pair into the B+ tree.\\n        \\n        Parameters:\\n            key (int): The key to insert.\\n            value (any): The value associated with the key.\\n        \\\"\\\"\\\"\\n        root = self.root\\n        if len(root.keys) == self.order - 1:\\n            new_root = Node()\\n            new_root.children.append(self.root)\\n            self._split_child(new_root, 0)\\n            self.root = new_root\\n            self._insert_non_full(new_root, key, value)\\n        else:\\n            self._insert_non_full(root, key, value)\\n\\n    def delete(self, key):\\n        \\\"\\\"\\\"Deletes a key from the B+ tree.\\n        \\n        Parameters:\\n            key (int): The key to delete.\\n        \\\"\\\"\\\"\\n        self._delete(self.root, key)\\n\\n    def _insert_non_full(self, node, key, value):\\n        \\\"\\\"\\\"Helper function to insert key in a node that is not full.\\\"\\\"\\\"\\n        if node.is_leaf:\\n            i = 0\\n            while i < len(node.keys) and node.keys[i] < key:\\n                i += 1\\n            node.keys.insert(i, key)\\n            node.children.insert(i, value)\\n        else:\\n            i = 0\\n            while i < len(node.keys) and node.keys[i] < key:\\n                i += 1\\n            child = node.children[i]\\n            if len(child.keys) == self.order - 1:\\n                self._split_child(node, i)\\n                if key > node.keys[i]:\\n                    i += 1\\n            self._insert_non_full(node.children[i], key, value)\\n\\n    def _split_child(self, parent, index):\\n        \\\"\\\"\\\"Split the child of parent node at index.\\\"\\\"\\\"\\n        order = self.order\\n        child = parent.children[index]\\n        new_child = Node(is_leaf=child.is_leaf)\\n        parent.keys.insert(index, child.keys[order // 2])\\n        parent.children.insert(index + 1, new_child)\\n\\n        new_child.keys = child.keys[order // 2 + 1:]\\n        child.keys = child.keys[:order // 2]\\n\\n        if not child.is_leaf:\\n            new_child.children = child.children[order // 2 + 1:]\\n            child.children = child.children[:order // 2 + 1]\\n\\n    def _delete(self, node, key):\\n        \\\"\\\"\\\"Helper function to delete key from the B+ tree.\\\"\\\"\\\"\\n        # Implement deletion logic for B+ tree nodes\\n        if node.is_leaf:\\n            if key in node.keys:\\n                index = node.keys.index(key)\\n                node.keys.pop(index)\\n                node.children.pop(index)\\n        else:\\n            i = self._find_key_index(node, key)\\n            if i < len(node.keys) and node.keys[i] == key:\\n                self._delete_internal(node, key, i)\\n            else:\\n                child = node.children[i]\\n                if len(child.keys) < (self.order + 1) // 2:\\n                    self._fix_tree(node, i)\\n                self._delete(node.children[i], key)\\n\\n    def _find_key_index(self, node, key):\\n        \\\"\\\"\\\"Returns index of a key within a node.\\\"\\\"\\\"\\n        i = 0\\n        while i < len(node.keys) and node.keys[i] < key:\\n            i += 1\\n        return i\\n\\n    def _delete_internal(self, node, key, i):\\n        \\\"\\\"\\\"Handle key deletion for internal nodes.\\\"\\\"\\\"\\n        prev_child = node.children[i]\\n        next_child = node.children[i + 1]\\n\\n        if len(prev_child.keys) >= (self.order + 1) // 2:\\n            pred = self._get_predecessor(prev_child)\\n            node.keys[i] = pred\\n            self._delete(prev_child, pred)\\n        elif len(next_child.keys) >= (self.order + 1) // 2:\\n            succ = self._get_successor(next_child)\\n            node.keys[i] = succ\\n            self._delete(next_child, succ)\\n        else:\\n            self._merge_nodes(node, i)\\n            self._delete(prev_child, key)\\n\\n    def _get_predecessor(self, node):\\n        \\\"\\\"\\\"Get the predecessor key from a node.\\\"\\\"\\\"\\n        while not node.is_leaf:\\n            node = node.children[-1]\\n        return node.keys[-1]\\n\\n    def _get_successor(self, node):\\n        \\\"\\\"\\\"Get the successor key from a node.\\\"\\\"\\\"\\n        while not node.is_leaf:\\n            node = node.children[0]\\n        return node.keys[0]\\n\\n    def _merge_nodes(self, parent, index):\\n        \\\"\\\"\\\"Merge sibling and node for key removal.\\\"\\\"\\\"\\n        child = parent.children[index]\\n        sibling = parent.children[index + 1]\\n        child.keys.append(parent.keys.pop(index))\\n        child.keys.extend(sibling.keys)\\n\\n        if not child.is_leaf:\\n            child.children.extend(sibling.children)\\n\\n        parent.children.pop(index + 1)\\n\\n    def _fix_tree(self, parent, index):\\n        \\\"\\\"\\\"Repair tree when a child has fewer keys than needed.\\\"\\\"\\\"\\n        if index > 0 and len(parent.children[index - 1].keys) >= (self.order + 1) // 2:\\n            self._shift_right(parent, index)\\n        elif index < len(parent.children) - 1 and len(parent.children[index + 1].keys) >= (self.order + 1) // 2:\\n            self._shift_left(parent, index)\\n        else:\\n            if index < len(parent.children) - 1:\\n                self._merge_nodes(parent, index)\\n            else:\\n                self._merge_nodes(parent, index - 1)\\n\\n    def _shift_right(self, parent, index):\\n        \\\"\\\"\\\"Shift keys from left sibling.\\\"\\\"\\\"\\n        child = parent.children[index]\\n        left_sibling = parent.children[index - 1]\\n        child.keys.insert(0, parent.keys[index - 1])\\n        parent.keys[index - 1] = left_sibling.keys.pop(-1)\\n\\n        if not left_sibling.is_leaf:\\n            child.children.insert(0, left_sibling.children.pop(-1))\\n\\n    def _shift_left(self, parent, index):\\n        \\\"\\\"\\\"Shift keys from right sibling.\\\"\\\"\\\"\\n        child = parent.children[index]\\n        right_sibling = parent.children[index + 1]\\n        child.keys.append(parent.keys[index])\\n        parent.keys[index] = right_sibling.keys.pop(0)\\n\\n        if not right_sibling.is_leaf:\\n            child.children.append(right_sibling.children.pop(0))\"}"}
