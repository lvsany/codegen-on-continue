er = order\\n\\n    def insert(self, key: int):\\n        \"\"\"Inserts a key into the B+ tree and handles node splits if necessary.\\n\\n        Args:\\n            key (int): The key to insert into the tree.\\n        \"\"\"\\n        node = self.root\\n\\n        # If root is full, split it\\n        if len(node.keys) == self.order - 1:\\n            new_root = Node(is_leaf=False)\\n            new_root.children.append(self.root)\\n            self._split_child(new_root, 0)\\n            self.root = new_root\\n\\n        # Insert the key into the appropriate node\\n        self._insert_non_full(self.root, key)\\n\\n    def delete(self, key: int):\\n        \"\"\"Removes a key from the B+ tree, ensuring tree properties are maintained.\\n\\n        Args:\\n            key (int): The key to delete from the tree.\\n        \"\"\"\\n        # Simple recursive delete operation\\n        self._delete_key(self.root, key)\\n\\n        # Adjust the root if necessary\\n        if len(self.root.keys) == 0 and not self.root.is_leaf:\\n            self.root = self.root.children[0]  # The only child becomes the new root\\n\\n    def search(self, key: int) -> bool:\\n        \"\"\"Searches for a key in the B+ tree, returning its presence status.\\n\\n        Args:\\n            key (int): The key to search in the tree.\\n\\n        Returns:\\n            bool: True if the key is found, False otherwise.\\n        \"\"\"\\n        node = self.root\\n        return self._search_key(node, key)\\n\\n    def range_query(self, start_key: int, end_key: int) -> List[int]:\\n        \"\"\"Returns a list of keys within the specified range.\\n\\n        Args:\\n            start_key (int): The starting key of the range.\\n            end_key (int): The ending key of the range.\\n\\n        Returns:\\n            List[int]: A list of keys within the specified range.\\n        \"\"\"\\n        node = self.root\\n        result = []\\n        self._range_query(node, start_key, end_key, result)