ules': [{'name': 'lib', 'description': 'Contains core implementations of the B+ tree data structure.', 'files': [{'name': 'bplustree.h', 'path': 'lib/bplustree.h', 'description': 'Header file defining the core data structures and public API functions for the B+ tree implementation.', 'global_code': {'globalVariables': [{'name': 'MIN_CACHE_NUM', 'type': 'int', 'description': 'Minimum number of cache slots, set to 5.'}], 'globalBlocks': []}, 'classes': [{'name': 'bplus_tree', 'description': 'Main B+ tree structure holding cache, file descriptor, root offset, and free blocks list.', 'attributes': [], 'methods': [{'name': 'bplus_tree_init', 'description': 'Initialize a B+ tree from a file or create a new one.', 'return_type': 'struct bplus_tree*', 'parameters': [{'name': 'filename', 'type': 'const char*', 'description': 'The name of the file to store the B+ tree.'}, {'name': 'block_size', 'type': 'int', 'description': 'Configurable block size, must be a power of 2.'}]}, {'name': 'bplus_tree_deinit', 'description': 'Clean up tree resources and save metadata to boot file.', 'return_type': 'void', 'parameters': [{'name': 'tree', 'type': 'struct bplus_tree*', 'description': 'Pointer to the B+ tree to be deinitialized.'}]}, {'name': 'bplus_tree_get', 'description': 'Retrieve value associated with a given key.', 'return_type': 'long', 'parameters': [{'name': 'tree', 'type': 'struct bplus_tree*', 'description': 'Pointer to the B+ tree to be queried.'}, {'name': 'key', 'type': 'long', 'description': 'The key whose value is to be retrieved.'}]}, {'name': 'bplus_tree_put', 'description': 'Insert a key-value pair or delete a key-value pair if data is zero.', 'return_type': 'void', 'parameters': [{'name': 'tree', 'type': 'struct bplus_tree*', 'description': 'Pointer to the B+ tree where key-value pair is to be inserted or deleted.'}, {'name': 'key', 'type': 'long', 'description': 'The key to be inserted or deleted.'}, {'name': 'data', 'type': 'long', 'description': 'The value to be