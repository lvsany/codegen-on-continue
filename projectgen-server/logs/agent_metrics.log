r internal node.\"\"\"\\n        self.keys = []  # type: List[int]\\n        self.children = []  # type: List[Node]\\n        self.is_leaf = is_leaf  # type: bool\\n\\n    def insert_key(self, key: int):\\n        \"\"\"Inserts a key into the node while maintaining sorted order.\\n\\n        Args:\\n            key (int): The key to insert into the node.\\n        \"\"\"\\n        # Insert key in sorted order\\n        if not self.keys:\\n            self.keys.append(key)\\n        else:\\n            for i, existing_key in enumerate(self.keys):\\n                if key < existing_key:\\n                    self.keys.insert(i, key)\\n                    break\\n            else:\\n                self.keys.append(key)\\n\\n    def split(self) -> \\'Node\\':\\n        \"\"\"Returns the new node created after the split.\\n\\n        Returns:\\n            Node: The new node after splitting.\\n        \"\"\"\\n        # Assuming a simple split logic based on a middle index\\n        mid_index = len(self.keys) // 2\\n        new_node = Node(self.is_leaf)\\n\\n        # Transfer half the keys and children to the new node\\n        new_node.keys = self.keys[mid_index:]\\n        self.keys = self.keys[:mid_index]\\n\\n        if not self.is_leaf:\\n            new_node.children = self.children[mid_index:]\\n            self.children = self.children[:mid_index]\\n\\n        return new_node\\n', 'diff': ''}, {'path': 'bplustree/bplustree.py', 'code': 'from typing import List, Optional\\nfrom bplustree.node import Node\\n\\nclass BPlusTree:\\n    \"\"\"Manages the B+ tree structure and provides interfaces for insertion, deletion, search, and other tree operations.\"\"\"\\n\\n    def __init__(self, order: int):\\n        \"\"\"Initializes a B+ tree with the given order.\\n\\n        Args:\\n            order (int): The order of the B+ tree, indicating the maximum number of children for internal nodes.\\n        \"\"\"\\n        self.root = Node(is_leaf=True)\\n        self.ord