ldren.append(self.root)\\n            self._split_child(new_root, 0)\\n            self.root = new_root\\n        self._insert_non_full(self.root, key, value)\\n\\n    def _split_child(self, parent: 'BPlusTree.Node', index: int) -> None:\\n        \\\"\\\"\\\"Splits the child of a node at a given index.\\\"\\\"\\\"\\n        node_to_split = parent.children[index]\\n        new_node = self.Node(is_leaf=node_to_split.is_leaf)\\n        mid_index = self.order // 2\\n        parent.keys.insert(index, node_to_split.keys[mid_index])\\n        parent.children.insert(index + 1, new_node)\\n        new_node.keys = node_to_split.keys[mid_index + 1:]\\n        node_to_split.keys = node_to_split.keys[:mid_index]\\n        if not node_to_split.is_leaf:\\n            new_node.children = node_to_split.children[mid_index + 1:]\\n            node_to_split.children = node_to_split.children[:mid_index + 1]\\n\\n    def _insert_non_full(self, node: 'BPlusTree.Node', key: int, value: any) -> None:\\n        \\\"\\\"\\\"Inserts a key into a node that is not full.\\\"\\\"\\\"\\n        if node.is_leaf:\\n            index = 0\\n            while index < len(node.keys) and node.keys[index] < key:\\n                index += 1\\n            node.keys.insert(index, key)\\n            node.children.insert(index, value)\\n        else:\\n            index = 0\\n            while index < len(node.keys) and node.keys[index] < key:\\n                index += 1\\n            if len(node.children[index].keys) == (self.order - 1):\\n                self._split_child(node, index)\\n                if key > node.keys[index]:\\n                    index += 1\\n            self._insert_non_full(node.children[index], key, value)\\n\\n    def search(self, key: int) -> any:\\n        \\\"\\\"\\\"Searches for a key in the B+ tree and returns its value.\\n\\n        :param key: The key to search for.\\n        \\\"\\\"\\\"\\n        return self._search(self.root, key)\\n\\n    def _search(self, node: 'BPlusTree.Node', key: int) -> any:\\n        \\\"\\\"\\\"Helper function to search for a key in a given node.\\\"\\\"\\\"\\n        index = 0\\n        while index < len(node.keys) and key > node.keys[index]:\\n            index += 1\\n        if index < len(node.keys) and key == node.keys[index]:\\n            if node.is_leaf:\\n                return node.children[index]\\n            else:\\n                return self._search(node.children[index + 1], key)\\n        elif node.is_leaf:\\n            return None\\n        else:\\n            return self._search(node.children[index], key)\\n\\n    def delete(self, key: int) -> None:\\n        \\\"\\\"\\\"Deletes a key-value pair from the B+ tree.\\n\\n        :param key: The key to delete.\\n        \\\"\\\"\\\"\\n        self._delete(self.root, key)\\n        if len(self.root.keys) == 0 and not self.root.is_leaf:\\n            self.root = self.root.children[0]\\n\\n    def _delete(self, node: 'BPlusTree.Node', key: int) -> None:\\n        \\\"\\\"\\\"Helper function to delete a key from a given node.\\\"\\\"\\\"\\n        index = 0\\n        while index < len(node.keys) and key > node.keys[index]:\\n            index += 1\\n        if index < len(node.keys) and key == node.keys[index]:\\n            if node.is_leaf:\\n                node.keys.pop(index)\\n                node.children.pop(index)\\n            else:\\n                self._delete_internal_node(node, key, index)\\n        elif not node.is_leaf:\\n            if len(node.children[index].keys) < (self.order // 2):\\n                self._rebalance(node, index)\\n            self._delete(node.children[index], key)\\n\\n    def _delete_internal_node(self, node: 'BPlusTree.Node', key: int, index: int) -> None:\\n        \\\"\\\"\\\"Deletes a key from an internal node.\\\"\\\"\\\"\\n        # This is a simplified version and may not handle all cases\\n        node.keys.pop(index)\\n        node.children.pop(index + 1)\\n\\n    def _rebalance(self, parent: 'BPlusTree.Node', index: int) -> None:\\n        \\\"\\\"\\\"Rebalances the tree after deletion.\\\"\\\"\\\"\\n        # This is a simplified version and may not handle all cases\\n        if index > 0 and len(parent.children[index - 1].keys) > (self.order // 2):\\n            left_sibling = parent.children[index - 1]\\n            child = parent.children[index]\\n            child.keys.insert(0, parent.keys[index - 1])\\n            parent.keys[index - 1] = left_sibling.keys.pop()\\n            if not left_sibling.is_leaf:\\n                child.children.insert(0, left_sibling.children.pop())\\n        elif index < len(parent.children) - 1 and len(parent.children[index + 1].keys) > (self.order // 2):\\n            right_sibling = parent.children[index + 1]\\n            child = parent.children[index]\\n            child.keys.append(parent.keys[index])\\n            parent.keys[index] = right_sibling.keys.pop(0)\\n            if not right_sibling.is_leaf:\\n                child.children.append(right_sibling.children.pop(0))\\n        else:\\n            if index > 0:\\n                self._merge_nodes(parent, index - 1)\\n            else:\\n                self._merge_nodes(parent, index)\\n\\n    def _merge_nodes(self, parent: 'BPlusTree.Node', index: int) -> None:\\n        \\\"\\\"\\\"Merges two nodes in the B+ tree.\\\"\\\"\\\"\\n        left_child = parent.children[index]\\n        right_child = parent.children[index + 1]\\n        left_child.keys.append(parent.keys.pop(index))\\n        left_child.keys.extend(right_child.keys)\\n        if not left_child.is_leaf:\\n            left_child.children.extend(right_child.children)\\n        parent.children.pop(index + 1)\\n\"}"}
